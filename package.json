{
  "name": "twin-md-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "twin-md monorepo: local-first sprite that reads your second brain.",
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @twin-md/core && npm run build -w @twin-md/mcp && npm run build -w @twin-md/web-lite && npm run build -w twin-md && npm run build -w @twin-md/web",
    "build:landing": "npm run build -w @twin-md/landing",
    "build:desktop": "npm run build -w @twin-md/desktop",
    "dev:web": "npm run dev -w @twin-md/web",
    "dev:landing": "npm run dev -w @twin-md/landing",
    "dev:desktop": "npm run dev -w @twin-md/desktop",
    "dev:web-lite": "npm run start -w @twin-md/web-lite",
    "generate:pet-assets": "node scripts/generate-pet-sprites-v2.mjs",
    "release": "./scripts/release.sh",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
