{
  "name": "twin-md",
  "version": "0.9.0",
  "description": "Local-first twin.md pet: CLI, MCP, Obsidian + Claude harvest, desktop companion.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/bin.js",
  "bin": {
    "twin-md": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "twin",
    "twin-md",
    "obsidian",
    "claude",
    "local-first",
    "mcp",
    "sprite",
    "pet",
    "reminders"
  ],
  "scripts": {
    "build": "tsup src/bin.ts --format esm --clean && node ../../scripts/add-shebang.mjs dist/bin.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@twin-md/brain": "^0.9.0",
    "@twin-md/core": "^0.9.0",
    "@twin-md/mcp": "^0.9.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.5"
  }
}
