{
  "name": "@twin-md/core",
  "version": "0.1.0",
  "description": "Local-first shared core for twin-md: schema, harvesters, interpretation, and reminder rule engine.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js",
      "default": "./dist/commands.js"
    },
    "./chat-commands": {
      "types": "./dist/chat-commands.d.ts",
      "import": "./dist/chat-commands.js",
      "default": "./dist/chat-commands.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts src/commands.ts src/chat-commands.ts --format esm --dts --no-splitting",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  }
}
