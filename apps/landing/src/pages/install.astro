---
import CozyLayout from '../layouts/CozyLayout.astro';
---

<CozyLayout title="install" active="install">
  <header class="mt-10 max-w-3xl">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">install</p>
    <h1 class="mt-2 font-display text-4xl sm:text-5xl">get your twin running</h1>
    <p class="mt-4 text-[var(--color-ink-soft)]">
      Node 20+ for the CLI/MCP server. The desktop app is Tauri (Rust + Vite). Everything important stays under <code class="rounded bg-[var(--color-cream)] px-1.5 py-0.5 text-sm">~/.claude/</code>; API keys are only needed for direct chat fallback or image generation.
    </p>
  </header>

  <!-- Section 1: One-liner -->
  <section class="mt-10" id="quick-start">
    <h2 class="font-display text-2xl">1. CLI + MCP</h2>
    <p class="mt-2 text-sm text-[var(--color-ink-soft)]">The fastest path. Scaffolds config, seeds twin.md, registers the MCP server.</p>
    <div class="mt-4 rounded-[2rem] border border-[var(--color-ink)]/10 bg-[var(--color-cream)] p-6 sm:p-8">
      <div class="flex items-center gap-2 rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-2 font-mono text-sm">
        <span class="text-[var(--color-ink-soft)]">$</span>
        <code>npx twin-md init</code>
        <button
          type="button"
          class="ml-auto rounded-md px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)] transition-colors hover:bg-[var(--color-cream)] hover:text-[var(--color-ink)]"
          data-copy="npx twin-md init"
        >copy</button>
      </div>
      <p class="mt-3 text-sm text-[var(--color-ink-soft)]">
        Writes <code class="rounded bg-[var(--color-paper)] px-1 text-xs">twin.config.json</code>, creates <code class="rounded bg-[var(--color-paper)] px-1 text-xs">~/.claude/twin.md</code>, and registers the twin MCP server for Claude Desktop.
      </p>
      <div class="mt-4 flex items-center gap-2 rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-2 font-mono text-sm">
        <span class="text-[var(--color-ink-soft)]">$</span>
        <code>twin-md action approve &lt;id&gt;</code>
        <button
          type="button"
          class="ml-auto rounded-md px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)] transition-colors hover:bg-[var(--color-cream)] hover:text-[var(--color-ink)]"
          data-copy="twin-md action approve <id>"
        >copy</button>
      </div>
      <p class="mt-2 text-sm text-[var(--color-ink-soft)]">
        Desktop handoffs start as <code class="rounded bg-[var(--color-paper)] px-1 text-xs">needs_approval</code>. Approve in Terminal; Claude Desktop then sees the action through MCP.
      </p>
    </div>
  </section>

  <!-- Section 2: Local dev from source -->
  <section class="mt-12" id="local-dev">
    <h2 class="font-display text-2xl">2. local dev from source</h2>
    <p class="mt-2 text-sm text-[var(--color-ink-soft)]">
      Hacking the repo: <code class="rounded bg-[var(--color-cream)] px-1 text-xs">apps/desktop</code> (Tauri + Rust IPC + Vite UI), <code class="rounded bg-[var(--color-cream)] px-1 text-xs">apps/landing</code> (Astro), <code class="rounded bg-[var(--color-cream)] px-1 text-xs">packages/core</code>, <code class="rounded bg-[var(--color-cream)] px-1 text-xs">packages/brain</code>, <code class="rounded bg-[var(--color-cream)] px-1 text-xs">packages/mcp</code>, and <code class="rounded bg-[var(--color-cream)] px-1 text-xs">packages/cli</code>.
    </p>
    <p class="mt-2 text-sm text-[var(--color-ink-soft)]">
      Prebuilt desktop: <a href="https://github.com/rzrizaldy/twin_md/releases" class="underline decoration-[var(--color-ink)]/30 hover:decoration-[var(--color-ink)]" target="_blank" rel="noreferrer">GitHub Releases</a> (look for <code class="rounded bg-[var(--color-cream)] px-1 text-xs">desktop-v*</code> tags).
    </p>
    <div class="mt-4 flex flex-col gap-3 rounded-[2rem] border border-[var(--color-ink)]/10 bg-[var(--color-cream)] p-6 sm:p-8">
      {[
        { cmd: 'git clone https://github.com/rzrizaldy/twin_md', hint: 'clone the monorepo' },
        { cmd: 'npm ci', hint: 'install workspace dependencies' },
        { cmd: 'npm run build', hint: 'build core, MCP, and CLI' },
        { cmd: 'npm run dev:desktop', hint: 'Tauri dev — floating pet + chat panel' },
      ].map((s) => (
        <div>
          <div class="flex items-center gap-2 rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-2 font-mono text-sm">
            <span class="text-[var(--color-ink-soft)]">$</span>
            <code>{s.cmd}</code>
            <button
              type="button"
              class="ml-auto rounded-md px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)] transition-colors hover:bg-[var(--color-cream)] hover:text-[var(--color-ink)]"
              data-copy={s.cmd}
            >copy</button>
          </div>
          <p class="mt-1 text-xs text-[var(--color-ink-soft)] pl-2">{s.hint}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section 3: Wire a provider key -->
  <section class="mt-12" id="api-keys">
    <h2 class="font-display text-2xl">3. optional provider keys</h2>
    <p class="mt-2 text-sm text-[var(--color-ink-soft)]">
      Claude Desktop MCP can handle local context. Add Anthropic/OpenAI/Gemini keys when you want direct in-app chat, generated backgrounds, or custom sprites.
    </p>
    <div class="mt-4 rounded-[2rem] border border-[var(--color-ink)]/10 bg-[var(--color-cream)] p-6 sm:p-8">
      <div class="flex gap-2 mb-6 border-b border-[var(--color-ink)]/10 pb-4" role="tablist" aria-label="provider tabs">
        <button class="provider-tab is-active" data-provider="anthropic" role="tab" aria-selected="true">anthropic</button>
        <button class="provider-tab" data-provider="openai" role="tab" aria-selected="false">openai</button>
        <button class="provider-tab" data-provider="gemini" role="tab" aria-selected="false">gemini</button>
      </div>

      <div class="provider-panel" data-panel="anthropic">
        <p class="text-sm text-[var(--color-ink-soft)] mb-3">Recommended model: <code class="rounded bg-[var(--color-paper)] px-1 text-xs">claude-haiku-4-5</code> — flash-equivalent, cheap, warm.</p>
        <div class="flex items-center gap-2 rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-2 font-mono text-sm mb-2">
          <code>export ANTHROPIC_API_KEY=sk-ant-…</code>
          <button type="button" class="ml-auto rounded-md px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]" data-copy="export ANTHROPIC_API_KEY=sk-ant-…">copy</button>
        </div>
        <a href="https://console.anthropic.com/settings/keys" target="_blank" rel="noreferrer" class="text-xs underline decoration-[var(--color-ink)]/30 hover:decoration-[var(--color-ink)]">get key at console.anthropic.com →</a>
      </div>

      <div class="provider-panel hidden" data-panel="openai">
        <p class="text-sm text-[var(--color-ink-soft)] mb-3">Recommended model: <code class="rounded bg-[var(--color-paper)] px-1 text-xs">gpt-5.4-mini</code> — most capable small model.</p>
        <div class="flex items-center gap-2 rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-2 font-mono text-sm mb-2">
          <code>export OPENAI_API_KEY=sk-…</code>
          <button type="button" class="ml-auto rounded-md px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]" data-copy="export OPENAI_API_KEY=sk-…">copy</button>
        </div>
        <a href="https://platform.openai.com/api-keys" target="_blank" rel="noreferrer" class="text-xs underline decoration-[var(--color-ink)]/30 hover:decoration-[var(--color-ink)]">get key at platform.openai.com →</a>
      </div>

      <div class="provider-panel hidden" data-panel="gemini">
        <p class="text-sm text-[var(--color-ink-soft)] mb-3">Recommended model: <code class="rounded bg-[var(--color-paper)] px-1 text-xs">gemini-3-flash-preview</code> — frontier fast.</p>
        <div class="flex items-center gap-2 rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-2 font-mono text-sm mb-2">
          <code>export GOOGLE_API_KEY=AIza…</code>
          <button type="button" class="ml-auto rounded-md px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]" data-copy="export GOOGLE_API_KEY=AIza…">copy</button>
        </div>
        <a href="https://aistudio.google.com/app/apikey" target="_blank" rel="noreferrer" class="text-xs underline decoration-[var(--color-ink)]/30 hover:decoration-[var(--color-ink)]">get key at aistudio.google.com →</a>
      </div>
    </div>
  </section>

  <!-- Section 4: Verify the pet is alive -->
  <section class="mt-12" id="verify">
    <h2 class="font-display text-2xl">4. verify the pet is alive</h2>
    <p class="mt-2 text-sm text-[var(--color-ink-soft)]">After first harvest, these files should exist:</p>
    <div class="mt-4 rounded-[2rem] border border-[var(--color-ink)]/10 bg-[var(--color-cream)] p-6 sm:p-8">
      <ul class="space-y-2 font-mono text-sm">
        {[
          '~/.claude/twin.md',
          '~/.claude/twin.config.json',
          '~/.claude/twin-state.json',
          '~/.claude/twin-buddy-memory.jsonl',
        ].map((f) => (
          <li class="flex items-center gap-2">
            <span class="text-[var(--color-ink-soft)]">✓</span>
            <code class="rounded bg-[var(--color-paper)] px-1.5 py-0.5">{f}</code>
          </li>
        ))}
      </ul>
      <div class="mt-6 border-t border-[var(--color-ink)]/10 pt-4">
        <p class="text-sm font-medium mb-2">run the pet in the terminal (or use the Tauri app after <code class="rounded bg-[var(--color-cream)] px-1 text-xs">npm run dev:desktop</code> / a release build):</p>
        <div class="flex items-center gap-2 rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-2 font-mono text-sm">
          <span class="text-[var(--color-ink-soft)]">$</span>
          <code>twin-md watch</code>
          <button type="button" class="ml-auto rounded-md px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]" data-copy="twin-md watch">copy</button>
        </div>
      </div>
      <details class="mt-6">
        <summary class="cursor-pointer text-sm font-medium text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">troubleshooting</summary>
        <div class="mt-3 space-y-3 text-sm text-[var(--color-ink-soft)]">
          <div>
            <p class="font-medium text-[var(--color-ink)]">desktop app won&rsquo;t start</p>
            <p>Build from <code class="rounded bg-[var(--color-cream)] px-1 text-xs">apps/desktop</code> with <code class="rounded bg-[var(--color-cream)] px-1 text-xs">npm run dev:desktop</code> (Vite must be on port 1420 in dev) or install a <a href="https://github.com/rzrizaldy/twin_md/releases" class="underline" target="_blank" rel="noreferrer">release</a> bundle. Check the terminal for a Rust or webview error.</p>
          </div>
          <div>
            <p class="font-medium text-[var(--color-ink)]">twin-md command not found</p>
            <p>Install globally: <code class="rounded bg-[var(--color-cream)] px-1 text-xs">npm install -g twin-md</code></p>
          </div>
          <div>
            <p class="font-medium text-[var(--color-ink)]">pet shows blank / default state</p>
            <p>Run <code class="rounded bg-[var(--color-cream)] px-1 text-xs">twin-md harvest</code> to pull fresh signals. The companion auto-updates.</p>
          </div>
        </div>
      </details>
    </div>
  </section>

  <section class="mt-12 mb-16" id="sprite-deps">
    <h2 class="font-display text-2xl">5. custom sprites</h2>
    <p class="mt-2 max-w-2xl text-sm text-[var(--color-ink-soft)]">
      Prompt and photo sprites use image generation plus optional background removal. The desktop onboarding can guide installation, or you can install it yourself:
    </p>
    <div class="mt-4 rounded-[2rem] border border-[var(--color-ink)]/10 bg-[var(--color-cream)] p-6 sm:p-8">
      <div class="flex items-center gap-2 rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-2 font-mono text-sm">
        <span class="text-[var(--color-ink-soft)]">$</span>
        <code>pipx install "rembg[cpu,cli]"</code>
        <button type="button" class="ml-auto rounded-md px-2 py-1 text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]" data-copy='pipx install "rembg[cpu,cli]"'>copy</button>
      </div>
      <p class="mt-3 text-sm text-[var(--color-ink-soft)]">
        <code class="rounded bg-[var(--color-paper)] px-1 text-xs">/change-char</code> creates a new character. <code class="rounded bg-[var(--color-paper)] px-1 text-xs">/evolution</code> iterates from the current sprite.
      </p>
    </div>
  </section>
</CozyLayout>

<style>
  .provider-tab {
    border-radius: 0.5rem;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    line-height: 1.25rem;
    color: var(--color-ink-soft);
    transition: color 0.15s ease;
  }
  .provider-tab:hover {
    color: var(--color-ink);
  }
  .provider-tab.is-active {
    background: var(--color-paper);
    color: var(--color-ink);
    font-weight: 500;
  }
  .provider-panel.hidden {
    display: none;
  }
</style>

<script>
  // Copy buttons
  for (const btn of document.querySelectorAll<HTMLButtonElement>('button[data-copy]')) {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy') ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const prev = btn.textContent;
        btn.textContent = 'copied';
        setTimeout(() => { btn.textContent = prev; }, 1200);
      } catch { /* silent */ }
    });
  }

  // Provider tabs
  const tabs = document.querySelectorAll<HTMLButtonElement>('.provider-tab');
  const panels = document.querySelectorAll<HTMLElement>('.provider-panel');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const provider = tab.dataset.provider;
      tabs.forEach((t) => { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach((p) => p.classList.add('hidden'));
      tab.classList.add('is-active');
      tab.setAttribute('aria-selected', 'true');
      document.querySelector<HTMLElement>(`.provider-panel[data-panel="${provider}"]`)?.classList.remove('hidden');
    });
  });
</script>
