---
import CozyLayout from '../layouts/CozyLayout.astro';
import BreathingSprite from '../components/BreathingSprite.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const scenes = [
  {
    slug: 'sunny_island',
    title: 'Bloom mode',
    kicker: 'healthy · open sky',
    blurb: 'When sleep, steps, and headspace line up — wide light, soft ground, creature dancing.',
    pet: { species: 'axolotl' as const, mood: 'healthy' as const },
    frame: 'from-[var(--color-mint)]/35 via-[var(--color-sand)]/25 to-[var(--color-pink)]/20',
  },
  {
    slug: 'stars_at_noon',
    title: 'Stars at noon',
    kicker: 'sleep deprived · low charge',
    blurb: 'The day feels half-lit. Yawns, slow blinks, and stubborn loyalty anyway.',
    pet: { species: 'axolotl' as const, mood: 'sleep_deprived' as const },
    frame: 'from-[var(--color-dusk)]/40 via-[var(--color-fog)]/30 to-[var(--color-storm)]/25',
  },
  {
    slug: 'storm_room',
    title: 'Paper storm',
    kicker: 'stressed · too many threads',
    blurb: 'Calendar density and context switches stack up — pacing energy, sharp edges, warm core.',
    pet: { species: 'axolotl' as const, mood: 'stressed' as const },
    frame: 'from-[var(--color-storm)]/45 via-[var(--color-dusk)]/25 to-[var(--color-fog)]/20',
  },
  {
    slug: 'grey_nook',
    title: 'Quiet corner',
    kicker: 'neglected · needs gentle return',
    blurb: 'When the glow drops — smaller room, softer saturation, still a friend in the nook.',
    pet: { species: 'axolotl' as const, mood: 'neglected' as const },
    frame: 'from-[var(--color-fog)]/50 via-[var(--color-cream)]/20 to-[var(--color-pink)]/15',
  },
] as const;
---

<CozyLayout title="world" active="world">
  <header class="relative mt-12 overflow-hidden rounded-[2.25rem] border border-[var(--color-ink)]/10 bg-gradient-to-br from-[var(--color-dusk)]/30 via-[var(--color-paper)] to-[var(--color-mint)]/20 p-8 sm:p-12">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -right-16 -top-24 h-64 w-64 rounded-full bg-[var(--color-axolotl-accent)]/15 blur-3xl"
    >
    </div>
    <div class="relative grid gap-10 lg:grid-cols-[1.05fr_1fr] lg:items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">phase three</p>
        <h1 class="mt-2 font-display text-4xl sm:text-5xl">an ambient world — later, but already painted</h1>
        <p class="mt-4 max-w-xl text-[var(--color-ink-soft)]">
          The desktop creature ships first. These are the same four environments the companion maps to when it reads your state — bloom, low charge, overload, quiet corner.
        </p>
        <p class="mt-3 max-w-xl text-[var(--color-ink-soft)]">
          Someday: shared browser meadows where twins meet. For now, wander the rooms below.
        </p>
      </div>
      <div class="relative">
        <div
          class="relative overflow-hidden rounded-[2rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] shadow-[0_28px_80px_-32px_rgba(71,54,67,0.45)]"
        >
          <div class="aspect-[4/3] w-full min-h-[220px] bg-[var(--color-fog)]/40 sm:min-h-[280px]">
            <img
              src={`${base}scenes/sunny_island/reference.png`}
              alt="Bloom mode — bright island scene concept"
              class="h-full w-full object-cover object-center"
              width="1536"
              height="1024"
              loading="eager"
            />
          </div>
          <div class="flex items-center justify-between gap-4 border-t border-[var(--color-ink)]/10 bg-[var(--color-cream)]/30 px-5 py-4">
            <p class="text-sm font-medium text-[var(--color-ink)]">Bloom mode preview</p>
            <BreathingSprite species="axolotl" mood="healthy" size={72} />
          </div>
        </div>
      </div>
    </div>
  </header>

  <section class="mt-14">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">mood board</p>
    <h2 class="mt-2 font-display text-3xl sm:text-4xl">four environments, full width</h2>
    <p class="mt-3 max-w-2xl text-[var(--color-ink-soft)]">
      Raster boards straight from production — same palette and lighting the pet scenes use.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      {
        scenes.map((s) => (
          <figure class="overflow-hidden rounded-[1.5rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] shadow-md">
            <div class="aspect-[3/2] w-full sm:aspect-[4/3]">
              <img
                src={`${base}scenes/${s.slug}/reference.png`}
                alt={`${s.title} environment`}
                width="800"
                height="533"
                class="h-full w-full object-cover object-center"
                loading="lazy"
              />
            </div>
            <figcaption class="border-t border-[var(--color-ink)]/10 px-4 py-3">
              <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-ink-soft)]">{s.kicker}</p>
              <p class="mt-0.5 font-display text-lg">{s.title}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <section class="mt-16">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">with the cast</p>
    <h2 class="mt-2 font-display text-3xl sm:text-4xl">same creature, different weather</h2>
    <p class="mt-3 max-w-2xl text-[var(--color-ink-soft)]">
      Each card pairs a scene with an axolotl pose on the matching mood lane.
    </p>

    <div class="mt-10 grid gap-8 lg:grid-cols-2">
      {
        scenes.map((s) => (
          <article
            class={`group relative overflow-hidden rounded-[2rem] border border-[var(--color-ink)]/10 bg-gradient-to-br ${s.frame} p-[1px] shadow-[0_24px_70px_-28px_rgba(71,54,67,0.4)]`}
          >
            <div class="relative h-full overflow-hidden rounded-[1.96rem] bg-[var(--color-paper)]/92 backdrop-blur-md dark:bg-[var(--color-paper)]/80">
              <div class="relative aspect-[16/11] w-full min-h-[200px] overflow-hidden bg-[var(--color-fog)]/35 sm:min-h-[260px]">
                <img
                  src={`${base}scenes/${s.slug}/reference.png`}
                  alt=""
                  width="960"
                  height="640"
                  class="h-full w-full object-cover object-center transition duration-[1.2s] ease-out group-hover:scale-[1.03]"
                  loading="lazy"
                />
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[var(--color-paper)]/45 via-transparent to-transparent opacity-90" />
              </div>
              <div class="relative flex flex-col gap-5 p-6 sm:flex-row sm:items-end sm:justify-between">
                <div class="max-w-lg">
                  <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">{s.kicker}</p>
                  <h3 class="mt-1 font-display text-2xl">{s.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-soft)]">{s.blurb}</p>
                </div>
                <div class="flex shrink-0 justify-center sm:justify-end">
                  <div class="rounded-2xl border border-[var(--color-ink)]/10 bg-[var(--color-cream)]/40 p-3">
                    <BreathingSprite species={s.pet.species} mood={s.pet.mood} size={108} />
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <p class="mx-auto mt-16 max-w-2xl text-center text-sm text-[var(--color-ink-soft)]">
    No mailing list — when the shared world ships, your running twin will be the first to grumble about it.
  </p>
</CozyLayout>
