---
import CozyLayout from '../layouts/CozyLayout.astro';

const sources = [
  { name: 'Apple Health', path: '~/twin-sources/health.json', hint: 'sleep · steps · HRV · workouts' },
  { name: 'Calendar ICS', path: '~/twin-sources/calendar.ics', hint: 'meeting load · density · deadlines' },
  { name: 'Claude memory', path: '~/.claude/', hint: 'CLAUDE.md · MEMORY.md · summaries' },
  { name: 'Obsidian vault', path: 'configurable', hint: 'recent notes · tags · unfinished todos' },
  { name: 'Location', path: '~/twin-sources/location.json', hint: 'home-ratio · novelty cues' },
];

const steps = [
  {
    k: '01 · harvest',
    t: 'local sources → one file',
    b: 'Health, calendar, Claude files, Obsidian, and optional location signals merge into ~/.claude/twin.md.',
  },
  {
    k: '02 · interpret',
    t: 'twin.md → twin-state.json',
    b: 'A local interpreter writes energy, stress, mood, scene, caption, and sprite state to one JSON file.',
  },
  {
    k: '03 · act',
    t: 'desktop + MCP',
    b: 'The Tauri companion queues desktop actions as local JSONL. Terminal approval flips them from needs_approval to pending, then Claude Desktop can execute through MCP.',
  },
];
---

<CozyLayout title="how it works" active="how">
  <header class="mt-10 max-w-3xl">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">architecture</p>
    <h1 class="mt-2 font-display text-4xl sm:text-5xl">local files, small surfaces</h1>
    <p class="mt-4 text-[var(--color-ink-soft)]">
      twin.md is a monorepo: TypeScript packages for CLI/core/MCP, an Astro landing page, and a Tauri desktop app with a Rust backend. The shared contract is still plain files under <code class="rounded bg-[var(--color-cream)] px-1.5 py-0.5 text-sm">~/.claude/</code>.
    </p>
  </header>

  <!-- Pipeline diagram -->
  <section class="mt-12 rounded-[2rem] border border-[var(--color-ink)]/10 bg-gradient-to-br from-[var(--color-cream)] to-[var(--color-mint)] p-6 sm:p-10">
    <div class="grid gap-4 text-sm sm:grid-cols-5 sm:items-stretch">
      <div class="rounded-2xl border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-4">
        <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)]">local sources</p>
        <ul class="mt-2 space-y-1 text-xs text-[var(--color-ink)]">
          {sources.map((s) => (
            <li>
              <span class="font-medium">{s.name}</span>
              <br />
              <code class="text-[10px] text-[var(--color-ink-soft)]">{s.path}</code>
            </li>
          ))}
        </ul>
      </div>

      <div class="flex flex-col items-center justify-center py-2 sm:py-0">
        <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-ink-soft)]">harvest</span>
        <span aria-hidden="true" class="mt-1 text-2xl text-[var(--color-ink-soft)] sm:hidden">↓</span>
        <span aria-hidden="true" class="mt-1 hidden text-2xl text-[var(--color-ink-soft)] sm:inline">→</span>
      </div>

      <div class="rounded-2xl border border-[var(--color-ink)]/20 bg-[var(--color-paper)] p-4 ring-2 ring-[var(--color-axolotl-accent)]/30">
        <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)]">single source of truth</p>
        <p class="mt-2 font-display text-xl">twin.md</p>
        <p class="mt-1 text-[11px] text-[var(--color-ink-soft)]">health · calendar · location · claude_memory_signals · obsidian_signals · now</p>
        <p class="mt-3 font-mono text-[10px] text-[var(--color-ink-soft)]">→ twin-state.json</p>
      </div>

      <div class="flex flex-col items-center justify-center py-2 sm:py-0">
        <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-ink-soft)]">render</span>
        <span aria-hidden="true" class="mt-1 text-2xl text-[var(--color-ink-soft)] sm:hidden">↓</span>
        <span aria-hidden="true" class="mt-1 hidden text-2xl text-[var(--color-ink-soft)] sm:inline">→</span>
      </div>

      <div class="rounded-2xl border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-4">
        <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-[var(--color-ink-soft)]">every surface</p>
        <ul class="mt-2 space-y-1 text-xs text-[var(--color-ink)]">
          <li>Terminal pet (<code class="text-[10px]">twin watch</code>)</li>
          <li>Action approval (<code class="text-[10px]">twin-md action approve</code>)</li>
          <li>Tauri desktop companion</li>
          <li>Claude Desktop (MCP)</li>
          <li>Astro landing page</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Three steps -->
  <section class="mt-12 grid gap-4 sm:grid-cols-3">
    {
      steps.map((s) => (
        <article class="rounded-[1.5rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-6">
          <p class="font-mono text-xs text-[var(--color-ink-soft)]">{s.k}</p>
          <h3 class="mt-2 font-display text-xl">{s.t}</h3>
          <p class="mt-2 text-sm text-[var(--color-ink-soft)]">{s.b}</p>
        </article>
      ))
    }
  </section>
</CozyLayout>
