---
import CozyLayout from '../layouts/CozyLayout.astro';
import type { BrandMarkId } from '../brand-marks';
import BrandMark from '../components/BrandMark.astro';

const integrations: { name: string; role: string; tone: string; mark: BrandMarkId }[] = [
  { name: 'Obsidian', role: 'primary notes root', tone: 'bg-[#7c3aed]/10 text-[#5b21b6]', mark: 'obsidian' },
  { name: 'Claude Code', role: 'local chat · CLI + twin MCP', tone: 'bg-[#d97706]/10 text-[#92400e]', mark: 'anthropic' },
  { name: 'Claude Desktop', role: 'optional · MCP + actions', tone: 'bg-[#ea580c]/10 text-[#9a3412]', mark: 'anthropic' },
  { name: 'OpenAI', role: 'optional · sprites & backgrounds', tone: 'bg-[#10a37f]/10 text-[#047857]', mark: 'openai' },
  { name: 'Gemini', role: 'optional · sprites & backgrounds', tone: 'bg-[#4285f4]/10 text-[#1d4ed8]', mark: 'googlegemini' },
  { name: 'Spotify', role: 'after approve', tone: 'bg-[#1db954]/10 text-[#15803d]', mark: 'spotify' },
  { name: 'Playwright', role: 'after approve', tone: 'bg-[#2563eb]/10 text-[#1e40af]', mark: 'playwright' },
  { name: 'Reminders', role: 'after approve', tone: 'bg-[var(--color-pink)] text-[var(--color-ink)]', mark: 'apple' },
];
---

<CozyLayout
  title="how it works"
  description="twin.md: local-first chat via Claude Code or Codex CLI with twin MCP; optional API keys for sprites and backgrounds; optional Claude Desktop for MCP actions."
  active="how"
>
  <header class="mt-10 max-w-3xl">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">architecture</p>
    <h1 class="mt-2 font-display text-4xl sm:text-5xl">your vault stays the center</h1>
    <p class="mt-4 text-[var(--color-ink-soft)]">
      <strong>Everyday chat is local-first.</strong> The app prefers your installed <strong>Claude Code</strong> or <strong>Codex</strong> CLI, injects the bundled <strong>twin MCP</strong> server, and streams the reply into Twin—no Claude <em>Desktop</em> window required for typing in the app. When an Obsidian vault is configured, that vault is the notes root for retrieval and MCP tools; the fallback <code class="rounded bg-[var(--color-paper)] px-1 text-xs">~/twin-brain</code> tree is only used when there is no vault. Provider <strong>API keys are optional</strong>: use them for <strong>custom sprites</strong>, <strong>chat backgrounds</strong>, and (if you skip the CLI) <strong>in-app chat over HTTPS</strong> to Anthropic, OpenAI, or Gemini.
    </p>
  </header>

  <section
    class="how-flow mt-12 rounded-[2rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-6 sm:p-8"
    aria-label="Twin.md architecture diagram"
  >
    <div class="flex flex-wrap items-end justify-between gap-3">
      <h2 class="font-display text-2xl sm:text-3xl">system map</h2>
      <p class="text-xs text-[var(--color-ink-soft)]">Solid: main path. Dashed: optional Claude Desktop for queued actions.</p>
    </div>

    <div class="how-flow__diagram mt-8">
      <!-- 1: You → Twin -->
      <div class="how-flow__row how-flow__row--top">
        <div class="how-box how-box--compact">
          <div class="how-box__head">
            <BrandMark mark="user" size={26} />
            <div>
              <p class="how-box__title">You</p>
              <p class="how-box__sub">onboarding · picks vault</p>
            </div>
          </div>
        </div>
        <div class="how-flow__arrow how-flow__arrow--h" aria-hidden="true">
          <span />
        </div>
        <div class="how-box how-box--hero">
          <div class="how-box__head">
            <BrandMark mark="twin" size={34} />
            <div>
              <p class="how-box__title">Twin.md</p>
              <p class="how-box__sub">desktop app · chat · companion · Rust IPC</p>
            </div>
          </div>
        </div>
      </div>

      <div class="how-flow__spine" aria-hidden="true">
        <span class="how-flow__chev">↓</span>
      </div>

      <!-- 2: Three branches -->
      <div class="how-flow__row how-flow__row--triple">
        <div class="how-branch">
          <div class="how-box">
            <div class="how-box__head">
              <BrandMark mark="obsidian" size={26} />
              <div>
            <p class="how-box__title">Vault</p>
                <p class="how-box__sub">Obsidian / Markdown folder · primary notes root</p>
              </div>
            </div>
            <p class="how-box__pill">read · retrieve snippets · create quick notes</p>
          </div>
        </div>
        <div class="how-branch">
          <div class="how-box">
            <div class="how-box__head">
              <BrandMark mark="anthropic" size={26} />
              <div>
                <p class="how-box__title">Local chat</p>
                <p class="how-box__sub">Claude Code or Codex CLI on your Mac, with twin MCP wired in—answers stay in the subprocess, not in a browser tab.</p>
              </div>
            </div>
            <p class="how-box__pill">default for conversation</p>
          </div>
        </div>
        <div class="how-branch">
          <div class="how-box">
            <div class="how-box__head">
              <BrandMark mark="list" size={26} />
              <div>
                <p class="how-box__title">Action queue</p>
                <p class="how-box__sub">local JSONL on disk</p>
              </div>
            </div>
            <p class="how-box__pill">Spotify · Playwright · Reminders…</p>
          </div>
        </div>
      </div>

      <div class="how-flow__spine" aria-hidden="true">
        <span class="how-flow__chev">↓</span>
      </div>

      <div class="how-box how-box--wide how-box--note">
        <div class="how-box__head how-box__head--multi">
          <div class="how-box__marks" aria-hidden="true">
            <BrandMark mark="anthropic" size={24} />
            <BrandMark mark="openai" size={24} />
            <BrandMark mark="googlegemini" size={24} />
          </div>
          <div>
            <p class="how-box__title">Optional provider keys</p>
            <p class="how-box__sub">
              Add Anthropic, OpenAI, or Gemini in settings when you want <strong>AI-generated sprites</strong>, <strong>scene wallpapers</strong>, or <strong>cloud API chat</strong> without installing the CLI. Keys are not required to use vault tools or the local CLI path.
            </p>
          </div>
        </div>
      </div>

      <div class="how-flow__spine" aria-hidden="true">
        <span class="how-flow__chev">↓</span>
      </div>

      <!-- 3: Permission -->
      <div class="how-box how-box--wide">
        <div class="how-box__head">
          <BrandMark mark="shield" size={28} />
          <div>
            <p class="how-box__title">Permission center</p>
            <p class="how-box__sub">
              Approve once per capability · or use <code class="rounded bg-[var(--color-cream)] px-1 text-[11px]">twin-md action</code> in Terminal · same queue
            </p>
          </div>
        </div>
      </div>

      <div class="how-flow__spine how-flow__spine--dashed" aria-hidden="true">
        <span class="how-flow__chev">↓</span>
      </div>

      <!-- 4: Claude optional -->
      <div class="how-box how-box--wide how-box--dashed">
        <div class="how-box__head">
          <BrandMark mark="anthropic" size={28} />
          <div>
            <p class="how-box__title">Claude Desktop (separate app)</p>
            <p class="how-box__sub">
              Optional source setup registers the same twin MCP in <strong>Anthropic’s Claude Desktop</strong> so that app can read the configured Obsidian vault, poll the action queue, run computer-use, and resolve items. This does <em>not</em> replace in-app chat—it is an extra surface for power workflows.
            </p>
          </div>
        </div>
      </div>

      <div class="how-flow__spine how-flow__spine--dashed" aria-hidden="true">
        <span class="how-flow__chev">↓</span>
      </div>

      <!-- 5: Outcome -->
      <div class="how-box how-box--wide how-box--muted">
        <div class="how-box__head how-box__head--multi">
          <div class="how-box__marks" aria-hidden="true">
            <BrandMark mark="apple" size={24} />
            <BrandMark mark="spotify" size={24} />
            <BrandMark mark="playwright" size={24} />
          </div>
          <div>
            <p class="how-box__title">Real desktop &amp; apps</p>
            <p class="how-box__sub">OS-level work happens here after approval—not silently in someone else’s cloud.</p>
          </div>
        </div>
      </div>
    </div>

    <p class="mt-8 text-center font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--color-ink-soft)]">
      Source CLI path: <code class="rounded bg-[var(--color-cream)] px-1.5 py-0.5">node packages/cli/dist/bin.js harvest</code> → <code class="rounded bg-[var(--color-cream)] px-1.5 py-0.5">~/.claude/twin.md</code>
    </p>
  </section>

  <section class="mt-10 rounded-[2rem] border border-[var(--color-ink)]/10 bg-gradient-to-br from-[var(--color-cream)] to-[var(--color-mint)] p-6 sm:p-8">
    <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">integrations &amp; permissions</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {
        integrations.map((item) => (
          <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-ink)]/10 bg-[var(--color-paper)] px-3 py-1.5 text-sm">
            <BrandMark mark={item.mark} size={18} class="opacity-90" />
            <span class:list={['rounded-full px-2 py-0.5 text-xs font-semibold', item.tone]}>{item.name}</span>
            <span class="text-xs text-[var(--color-ink-soft)]">{item.role}</span>
          </span>
        ))
      }
    </div>
  </section>
</CozyLayout>

<style>
  .how-flow__diagram {
    max-width: 56rem;
    margin-left: auto;
    margin-right: auto;
  }

  .how-flow__row {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .how-flow__row--top {
    align-items: center;
  }

  .how-flow__row--triple {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .how-flow__row--triple {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .how-branch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    min-width: 0;
  }

  .how-branch .how-box {
    width: 100%;
  }

  .how-flow__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    color: var(--color-ink-soft);
  }

  .how-flow__arrow--h span {
    display: block;
    width: 2rem;
    height: 2px;
    background: color-mix(in srgb, var(--color-ink-soft) 55%, transparent);
    position: relative;
  }

  .how-flow__arrow--h span::after {
    content: '';
    position: absolute;
    right: -1px;
    top: 50%;
    transform: translateY(-50%);
    border: 5px solid transparent;
    border-left: 7px solid color-mix(in srgb, var(--color-ink-soft) 55%, transparent);
  }

  .how-flow__spine {
    display: flex;
    justify-content: center;
    padding: 0.2rem 0 0.35rem;
    position: relative;
  }

  .how-flow__spine::before {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0;
    bottom: 0;
    width: 2px;
    background: color-mix(in srgb, var(--color-ink-soft) 35%, transparent);
    z-index: 0;
  }

  .how-flow__spine--dashed::before {
    background: repeating-linear-gradient(
      to bottom,
      color-mix(in srgb, var(--color-ink-soft) 40%, transparent),
      color-mix(in srgb, var(--color-ink-soft) 40%, transparent) 5px,
      transparent 5px,
      transparent 9px
    );
    width: 2px;
  }

  .how-flow__chev {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 999px;
    font-size: 0.85rem;
    line-height: 1;
    color: var(--color-ink-soft);
    background: var(--color-paper);
    border: 1px solid color-mix(in srgb, var(--color-ink) 12%, transparent);
  }

  .how-box {
    border-radius: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--color-ink) 14%, transparent);
    background: var(--color-cream);
    padding: 1rem 1.15rem;
    box-shadow: 0 1px 0 color-mix(in srgb, var(--color-ink) 8%, transparent);
  }

  .how-box--compact {
    flex: 0 1 auto;
    min-width: 8.5rem;
  }

  .how-box--hero {
    flex: 1 1 18rem;
    max-width: 28rem;
    background: color-mix(in srgb, var(--color-mint) 50%, var(--color-paper));
    border-color: color-mix(in srgb, var(--color-axolotl-accent) 38%, var(--color-ink));
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-axolotl-accent) 18%, transparent);
  }

  .how-box--wide {
    width: 100%;
  }

  .how-box--dashed {
    border-style: dashed;
    border-color: color-mix(in srgb, var(--color-ink) 24%, transparent);
    background: color-mix(in srgb, var(--color-paper) 90%, var(--color-cream));
  }

  .how-box--muted {
    background: var(--color-paper);
  }

  .how-box--note {
    background: color-mix(in srgb, var(--color-mint) 22%, var(--color-cream));
    border-color: color-mix(in srgb, var(--color-ink) 12%, transparent);
  }

  .how-box__head {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .how-box__head--multi {
    align-items: center;
  }

  .how-box__marks {
    display: flex;
    flex-shrink: 0;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
  }

  .how-box__title {
    font-family: var(--font-display, ui-serif, Georgia, serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .how-box__sub {
    margin-top: 0.35rem;
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--color-ink-soft);
  }

  .how-box__pill {
    margin-top: 0.55rem;
    display: inline-block;
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    background: color-mix(in srgb, var(--color-ink) 7%, transparent);
  }

  @media (max-width: 640px) {
    .how-flow__arrow--h {
      display: none;
    }

    .how-flow__row--top {
      flex-direction: column;
      width: 100%;
    }

    .how-flow__row--top .how-box--hero {
      max-width: none;
      width: 100%;
    }

    .how-flow__row--top .how-box--compact {
      width: 100%;
    }
  }
</style>
