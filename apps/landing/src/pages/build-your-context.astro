---
import CozyLayout from '../layouts/CozyLayout.astro';
import KarpathyGist from '../components/KarpathyGist.astro';
import BreathingSprite from '../components/BreathingSprite.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<CozyLayout
  title="build your context"
  description="How to help twin.md understand you: start with an Obsidian vault, then optionally add a short CLAUDE.md file for voice and preferences."
  active="context"
>
  <header class="mt-10 grid gap-8 sm:grid-cols-[2fr_1fr] sm:items-center">
    <div>
      <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">feed your twin</p>
      <h1 class="mt-2 font-display text-4xl sm:text-5xl">your vault is the memory. your prompt is the voice.</h1>
      <p class="mt-4 max-w-2xl text-[var(--color-ink-soft)]">
        The fastest way to make Twin useful is to point it at the notes you already keep. If you want it to sound more like you, add a short <code class="rounded bg-[var(--color-cream)] px-1.5 py-0.5 text-sm">CLAUDE.md</code> with your working style.
      </p>
    </div>
    <div class="flex justify-center">
      <div class="rounded-[2rem] border border-[var(--color-ink)]/10 bg-[var(--color-pink)] p-6">
        <BreathingSprite species="axolotl" mood="healthy" size={180} />
      </div>
    </div>
  </header>

  <section class="mt-16 grid gap-4 sm:grid-cols-3">
    <article class="rounded-[1.5rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-6">
      <p class="font-mono text-xs text-[var(--color-ink-soft)]">01</p>
      <h2 class="mt-2 font-display text-xl">Choose your vault</h2>
      <p class="mt-2 text-sm text-[var(--color-ink-soft)]">
        Obsidian, a Markdown folder, class notes, project notes, daily logs — this is the real context.
      </p>
    </article>
    <article class="rounded-[1.5rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-6">
      <p class="font-mono text-xs text-[var(--color-ink-soft)]">02</p>
      <h2 class="mt-2 font-display text-xl">Ask specific questions</h2>
      <p class="mt-2 text-sm text-[var(--color-ink-soft)]">
        “What do I know about EVPI?” is better than “summarize my vault.” Twin retrieves matching notes first.
      </p>
    </article>
    <article class="rounded-[1.5rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-6">
      <p class="font-mono text-xs text-[var(--color-ink-soft)]">03</p>
      <h2 class="mt-2 font-display text-xl">Add voice later</h2>
      <p class="mt-2 text-sm text-[var(--color-ink-soft)]">
        A small CLAUDE.md file tells Twin how to speak, what to prioritize, and what to avoid.
      </p>
    </article>
  </section>

  <section class="mt-16">
    <h2 class="font-display text-2xl">what to put in CLAUDE.md</h2>
    <p class="mt-2 max-w-2xl text-sm text-[var(--color-ink-soft)]">
      This file is optional. Keep it short: identity, work style, and current focus.
    </p>

    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <article class="rounded-[1.5rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-6">
        <div class="mb-4 flex items-center gap-3">
          <img
            src={`${base}pets/axolotl/healthy/turn-front.png`}
            alt=""
            width="56"
            height="56"
            class="h-14 w-14 object-contain"
            loading="lazy"
          />
          <p class="font-mono text-xs text-[var(--color-ink-soft)]">{'{{role}}'}</p>
        </div>
        <h3 class="font-display text-xl">who you are</h3>
        <p class="mt-2 text-sm text-[var(--color-ink-soft)]">What you do, what you care about, and where you want the assistant to be careful.</p>
      </article>
      <article class="rounded-[1.5rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-6">
        <div class="mb-4 flex items-center gap-3">
          <img
            src={`${base}pets/axolotl/healthy/turn-front.png`}
            alt=""
            width="56"
            height="56"
            class="h-14 w-14 object-contain"
            loading="lazy"
          />
          <p class="font-mono text-xs text-[var(--color-ink-soft)]">{'{{values}}'}</p>
        </div>
        <h3 class="font-display text-xl">how you work</h3>
        <p class="mt-2 text-sm text-[var(--color-ink-soft)]">Your defaults: concise or detailed, direct or gentle, fast iteration or careful planning.</p>
      </article>
      <article class="rounded-[1.5rem] border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-6">
        <div class="mb-4 flex items-center gap-3">
          <img
            src={`${base}pets/axolotl/healthy/turn-front.png`}
            alt=""
            width="56"
            height="56"
            class="h-14 w-14 object-contain"
            loading="lazy"
          />
          <p class="font-mono text-xs text-[var(--color-ink-soft)]">{'{{current_focus}}'}</p>
        </div>
        <h3 class="font-display text-xl">what matters now</h3>
        <p class="mt-2 text-sm text-[var(--color-ink-soft)]">The current semester, product, job search, project, or life focus Twin should keep in mind.</p>
      </article>
    </div>

    <div class="mt-10 overflow-hidden rounded-[1.75rem] border border-[var(--color-ink)]/10 bg-[var(--color-fog)]/25">
      <div class="grid sm:grid-cols-4">
        {
          ['sunny_island', 'stars_at_noon', 'storm_room', 'grey_nook'].map((slug) => (
            <div class="relative aspect-[5/3] border-b border-[var(--color-ink)]/10 sm:border-b-0 sm:border-r sm:last:border-r-0">
              <img
                src={`${base}scenes/${slug}/reference.png`}
                alt=""
                class="h-full w-full object-cover object-center"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
      <p class="px-4 py-3 text-center font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">
        moods become scenes · same assets as the desktop pet
      </p>
    </div>
  </section>

  <KarpathyGist />

  <section class="mt-16 rounded-[1.75rem] border border-[var(--color-ink)]/10 bg-[var(--color-cream)] p-6 sm:p-8">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">starter file</p>
        <h2 class="mt-1 font-display text-2xl">CLAUDE.md template</h2>
        <p class="mt-1 text-sm text-[var(--color-ink-soft)]">Download, open in your editor, keep only what feels honest.</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href={`${base}claude-starter.md`} download class="inline-flex items-center gap-2 rounded-full bg-[var(--color-ink)] px-4 py-2 text-sm text-[var(--color-paper)] transition-transform hover:-translate-y-0.5">
          download CLAUDE.md
        </a>
        <a
          href="https://gist.github.com/karpathy/442a6bf555914893e9891c11519de94f"
          target="_blank"
          rel="noreferrer noopener"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--color-ink)]/20 px-4 py-2 text-sm transition-colors hover:bg-[var(--color-paper)]"
        >
          read Karpathy's gist →
        </a>
      </div>
    </div>

    <pre class="mt-6 overflow-x-auto rounded-lg border border-[var(--color-ink)]/10 bg-[var(--color-paper)] p-4 font-mono text-xs text-[var(--color-ink)]"><code># {'{{role}}'}
you are a {'{{short role}}'} who codes, writes, and thinks out loud.
you care about: {'{{3 bullets of values}}'}.

# {'{{values}}'}
- you block the first 3 hours of the day for one hard thing.
- you stop when it stops being fun, not when it stops being unfinished.
- when underwater, you drop: {'{{first thing to drop}}'}.

# {'{{current_focus}}'}
- the next two weeks are about {'{{specific outcome}}'}.
- the tell you’re off-track: {'{{specific signal}}'}.

# for the twin
- when I look tired, speak softer.
- when I look stressed, name only one thing to put down.
- when I’ve been quiet, ask what I’ve been avoiding, gently.</code></pre>
  </section>
</CozyLayout>
