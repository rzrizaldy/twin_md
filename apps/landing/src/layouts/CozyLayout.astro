---
import '../styles/global.css';
import CozyNav from '../components/CozyNav.astro';

interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'meet' | 'how' | 'install' | 'context' | 'world';
}

const {
  title,
  description = 'twin.md is a local desktop companion for Obsidian, Claude Desktop MCP, custom sprites, and chat context.',
  active = 'home',
} = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const baseUrl = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;

const fullTitle = active === 'home' ? title : `${title} — twin.md`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          var k = 'twin-md-theme';
          var s = localStorage.getItem(k);
          var t =
            s === 'light' || s === 'dark'
              ? s
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/png" href={`${baseUrl}pets/axolotl/healthy/breath-a.png`} />
  </head>
  <body class="min-h-dvh bg-[var(--color-paper)] text-[var(--color-ink)]">
    <!-- SVG filter for hand-drawn wobble on display type -->
    <svg width="0" height="0" aria-hidden="true" style="position:absolute">
      <filter id="wobble" x="-2%" y="-2%" width="104%" height="104%">
        <feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="2" seed="3" />
        <feDisplacementMap in="SourceGraphic" scale="1.2" />
      </filter>
    </svg>

    <CozyNav active={active} />

    <main class="mx-auto w-full max-w-6xl px-6 pb-24 sm:px-8">
      <slot />
    </main>

    <footer class="mx-auto mt-16 w-full max-w-6xl px-6 pb-12 sm:px-8">
      <div class="flex flex-wrap items-baseline justify-between gap-4 border-t border-[var(--color-ink)]/10 pt-6 text-sm text-[var(--color-ink-soft)]">
        <p>
          local-first. no accounts. no tracking. MIT.
        </p>
        <p>
          <a href="https://github.com/rzrizaldy/twin_md" class="underline decoration-[var(--color-ink)]/30 hover:decoration-[var(--color-ink)]">
            source
          </a>
          <span class="mx-2">·</span>
          <a href={`${baseUrl}build-your-context`} class="underline decoration-[var(--color-ink)]/30 hover:decoration-[var(--color-ink)]">
            feed your twin
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>
