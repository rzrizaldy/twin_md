---
interface Props {
  species?: 'axolotl' | 'cat' | 'slime';
  mood?: 'healthy' | 'sleep_deprived' | 'stressed' | 'neglected';
  size?: number;
  class?: string;
  drift?: boolean;
  /** Two-frame breath crossfade (desktop-style). Landing defaults to one still frame + optional float only. */
  breath?: boolean;
}

const {
  species = 'axolotl',
  mood = 'healthy',
  size = 240,
  class: className = '',
  drift = true,
  breath = false,
} = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const basePrefix = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const base = `${basePrefix}pets/${species}/${mood}`;
// Match desktop companion: raster sprites (clean exports), not vector previews.
const a = `${base}/breath-a.png`;
const b = `${base}/breath-b.png`;
const aRef = `${base}/breath-a-reference.png`;
const bRef = `${base}/breath-b-reference.png`;
const catFallbackA = `this.onerror=null;this.src='${a}'`;
const catFallbackB = `this.onerror=null;this.src='${b}'`;
---

<div
  class:list={['relative inline-block', className]}
  style={`width:${size}px;height:${size}px;${drift ? 'animation: drift 4.2s var(--ease-breath) infinite;' : ''}`}
  data-species={species}
  data-mood={mood}
>
  {
    breath ? (
      <>
        <img
          src={species === 'cat' ? aRef : a}
          alt=""
          aria-hidden="true"
          width={size}
          height={size}
          class="absolute inset-0 h-full w-full"
          style="animation: breath-a 2200ms var(--ease-breath) infinite;"
          loading="eager"
          decoding="async"
          {...species === 'cat' ? { onerror: catFallbackA } : {}}
        />
        <img
          src={species === 'cat' ? bRef : b}
          alt=""
          aria-hidden="true"
          width={size}
          height={size}
          class="absolute inset-0 h-full w-full"
          style="animation: breath-b 2200ms var(--ease-breath) infinite;"
          loading="eager"
          decoding="async"
          {...species === 'cat' ? { onerror: catFallbackB } : {}}
        />
      </>
    ) : (
      <img
        src={species === 'cat' ? aRef : a}
        alt=""
        aria-hidden="true"
        width={size}
        height={size}
        class="block h-full w-full"
        loading="eager"
        decoding="async"
        {...species === 'cat' ? { onerror: catFallbackA } : {}}
      />
    )
  }
</div>
